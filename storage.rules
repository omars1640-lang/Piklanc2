rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isSuperAdmin() {
      let admin = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      return isAdmin()
        && (admin.get("adminAccessLevel", "") == "super_admin" || !admin.keys().hasAny(["adminRoleId"]));
    }

    function hasAdminPermission(permission) {
      let admin = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      return isAdmin() && (
        isSuperAdmin()
        || (
          admin.adminRoleId is string
          && firestore.exists(/databases/(default)/documents/adminRoles/$(admin.adminRoleId))
          && permission in firestore.get(/databases/(default)/documents/adminRoles/$(admin.adminRoleId)).data.get("permissions", [])
        )
      );
    }

    function activeUser() {
      return signedIn()
        && request.auth.token.email_verified == true
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.status == "active";
    }

    function activePortfolioOwner(userId) {
      let user = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      return signedIn()
        && request.auth.uid == userId
        && user.status == "active"
        && user.accountType == "freelancer";
    }

    function isChatParticipant(chatId) {
      return activeUser()
        && request.auth.uid in firestore.get(
          /databases/(default)/documents/chats/$(chatId)
        ).data.participantUids;
    }

    match /identity/{userId}/{fileName} {
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && fileName in ["front", "back"]
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
      allow delete: if signedIn() && (request.auth.uid == userId || hasAdminPermission("verifications.manage"));
      allow read: if signedIn() && (request.auth.uid == userId || hasAdminPermission("verifications.view"));
    }

    match /chat-attachments/{chatId}/{messageId}/{fileName} {
      allow create: if isChatParticipant(chatId)
        && request.resource.size > 0
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches(
          "image/(jpeg|png|webp)|application/(pdf|msword|vnd.openxmlformats-officedocument.wordprocessingml.document|zip|x-zip-compressed)"
        );
      allow read: if isChatParticipant(chatId);
      allow delete: if isChatParticipant(chatId);
      allow update: if false;
    }

    match /article-covers/{articleId}/{fileName} {
      allow read: if true;
      allow create, update: if hasAdminPermission("content.manage")
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if hasAdminPermission("content.manage");
    }

    match /service-images/{userId}/{serviceId}/{fileName} {
      allow read: if true;
      allow create, update: if activeUser()
        && request.auth.uid == userId
        && fileName.matches("cover\\.(jpg|png|webp)")
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if hasAdminPermission("services.moderate") || (activeUser() && request.auth.uid == userId);
    }

    match /profile-images/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if activeUser()
        && request.auth.uid == userId
        && fileName == "avatar"
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if activeUser() && request.auth.uid == userId && fileName == "avatar";
    }

    match /freelancer-portfolio/{userId}/{itemId}/{fileName} {
      allow read: if true;
      allow create, update: if activePortfolioOwner(userId)
        && fileName.matches("cover\\.(jpg|png|webp|mp4|webm|mov)")
        && request.resource.size > 0
        && (
          (
            request.resource.size <= 5 * 1024 * 1024
            && request.resource.contentType.matches("image/(jpeg|png|webp)")
          )
          || (
            request.resource.size <= 50 * 1024 * 1024
            && request.resource.contentType.matches("video/(mp4|webm|quicktime)")
          )
        );
      allow delete: if hasAdminPermission("services.moderate") || activePortfolioOwner(userId);
    }

    match /portfolio-media/{userId}/{itemId}/{fileName} {
      allow read: if true;
      allow create, update: if activePortfolioOwner(userId)
        && fileName.matches("cover\\.(jpg|png|webp|mp4|webm|mov)")
        && request.resource.size > 0
        && (
          (
            request.resource.size <= 5 * 1024 * 1024
            && request.resource.contentType.matches("image/(jpeg|png|webp)")
          )
          || (
            request.resource.size <= 50 * 1024 * 1024
            && request.resource.contentType.matches("video/(mp4|webm|quicktime)")
          )
        );
      allow delete: if hasAdminPermission("services.moderate") || activePortfolioOwner(userId);
    }

    match /portfolio-images/{userId}/{itemId}/{fileName} {
      allow read: if true;
      allow create, update: if activePortfolioOwner(userId)
        && fileName.matches("cover\\.(jpg|png|webp)")
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if hasAdminPermission("services.moderate") || activePortfolioOwner(userId);
    }

    match /payment-receipts/{userId}/{requestId}/{fileName} {
      allow read: if hasAdminPermission("finance.view") || (activeUser() && request.auth.uid == userId);
      allow create: if activeUser()
        && request.auth.uid == userId
        && fileName.matches("receipt\\.(jpg|png|webp)")
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow update: if false;
      allow delete: if hasAdminPermission("finance.manage") || (activeUser() && request.auth.uid == userId);
    }

    match /payout-qr/{userId}/sham_cash/{fileName} {
      allow read: if hasAdminPermission("finance.view") || (activeUser() && request.auth.uid == userId);
      allow create, update: if activeUser()
        && request.auth.uid == userId
        && fileName.matches("qr\\.(jpg|png|webp)")
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if hasAdminPermission("finance.manage") || (activeUser() && request.auth.uid == userId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
