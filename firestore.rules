rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function activeUser() {
      return verified()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "active";
    }

    function isAdmin() {
      return verified()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "active";
    }

    function isSuperAdmin() {
      let admin = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAdmin()
        && (admin.get("adminAccessLevel", "") == "super_admin" || !admin.keys().hasAny(["adminRoleId"]));
    }

    function hasAdminPermission(permission) {
      let admin = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAdmin() && (
        isSuperAdmin()
        || (
          admin.adminRoleId is string
          && exists(/databases/$(database)/documents/adminRoles/$(admin.adminRoleId))
          && get(/databases/$(database)/documents/adminRoles/$(admin.adminRoleId)).data.get("active", true) != false
          && permission in get(/databases/$(database)/documents/adminRoles/$(admin.adminRoleId)).data.get("permissions", [])
        )
      );
    }

    function canCreateAuditAction(action) {
      return (action in ["approve_user", "reject_user"] && hasAdminPermission("verifications.manage"))
        || (action in ["suspend_user", "activate_user"] && hasAdminPermission("users.manage"))
        || (action == "update_settings" && hasAdminPermission("settings.manage"))
        || (action in ["update_ticket", "reply_ticket"] && hasAdminPermission("support.reply"))
        || (action in ["create_article", "update_article", "delete_article", "manage_faq", "manage_category"] && hasAdminPermission("content.manage"))
        || (action in ["approve_service", "reject_service", "delete_service"] && hasAdminPermission("services.moderate"))
        || (action == "update_freelancer_rank" && hasAdminPermission("ranks.manage"))
        || (action in ["create_promo_codes", "assign_badge", "create_badge"] && hasAdminPermission("promotions.manage"));
    }

    function isAccountType(type) {
      return activeUser()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == type;
    }

    function isChatParticipant(chatId) {
      return activeUser()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantUids;
    }

    function userAfter(userId) {
      return getAfter(/databases/$(database)/documents/users/$(userId)).data;
    }

    function activeParticipant(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.status == "active";
    }

    function validEmail(value) {
      return value is string
        && value.size() >= 6
        && value.size() <= 160
        && value.matches("^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$");
    }

    function validAdminNotification(data) {
      return data.keys().hasOnly(["title", "body", "link", "type", "relatedOrderId", "read", "createdAt"])
        && data.keys().hasAll(["title", "body", "read", "createdAt"])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 140
        && data.body is string && data.body.size() <= 500
        && data.read == false
        && data.createdAt == request.time
        && (!data.keys().hasAny(["link"]) || (data.link is string && data.link.matches("^[A-Za-z0-9][A-Za-z0-9._/?#=&%-]{0,299}$")))
        && (!data.keys().hasAny(["type"]) || (data.type is string && data.type.size() <= 60))
        && (!data.keys().hasAny(["relatedOrderId"]) || (data.relatedOrderId is string && data.relatedOrderId.size() <= 100));
    }

    function validPlatformSettings(data) {
      return data.keys().hasOnly([
          "maintenanceMode", "prelaunchMode", "registrationsEnabled",
          "freelancerApplicationsEnabled", "platformFeePercent",
          "supportEmail", "platformName", "homeFeaturedBadgeIds", "homeFeaturedCriteria", "updatedAt", "updatedBy"
        ])
        && data.maintenanceMode is bool
        && data.prelaunchMode is bool
        && data.registrationsEnabled is bool
        && data.freelancerApplicationsEnabled is bool
        && data.platformFeePercent is number
        && data.platformFeePercent >= 0
        && data.platformFeePercent <= 100
        && data.supportEmail is string
        && data.supportEmail.size() <= 160
        && data.platformName is string
        && data.platformName.size() > 0
        && data.platformName.size() <= 60
        && (!data.keys().hasAny(["homeFeaturedBadgeIds"])
          || (data.homeFeaturedBadgeIds is list && data.homeFeaturedBadgeIds.size() <= 50))
        && (!data.keys().hasAny(["homeFeaturedCriteria"])
          || (data.homeFeaturedCriteria is list && data.homeFeaturedCriteria.size() <= 50))
        && data.updatedAt == request.time
        && data.updatedBy == request.auth.uid;
    }

    function validParticipantMap(data, field) {
      return data[field] is map
        && data[field].keys().hasOnly(data.participantUids);
    }

    function validUnreadCounts(data) {
      return validParticipantMap(data, "unreadCounts")
        && data.unreadCounts[data.participantUids[0]] is int
        && data.unreadCounts[data.participantUids[0]] >= 0
        && data.unreadCounts[data.participantUids[1]] is int
        && data.unreadCounts[data.participantUids[1]] >= 0;
    }

    function validParticipantTypes(data) {
      return validParticipantMap(data, "participantTypes")
        && data.participantTypes[data.participantUids[0]] in ["buyer", "freelancer"]
        && data.participantTypes[data.participantUids[1]] in ["buyer", "freelancer"]
        && data.participantTypes[data.participantUids[0]] == get(
          /databases/$(database)/documents/users/$(data.participantUids[0])
        ).data.accountType
        && data.participantTypes[data.participantUids[1]] == get(
          /databases/$(database)/documents/users/$(data.participantUids[1])
        ).data.accountType;
    }

    function otherParticipant(data) {
      return data.participantUids[0] == request.auth.uid
        ? data.participantUids[1]
        : data.participantUids[0];
    }

    function validChatUpdate() {
      let otherUid = otherParticipant(resource.data);
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return (
        changed.hasOnly(["unreadCounts"])
        && request.resource.data.unreadCounts[request.auth.uid] == 0
        && request.resource.data.unreadCounts[otherUid] == resource.data.unreadCounts[otherUid]
      ) || (
        changed.hasOnly([
          "lastMessage", "lastMessageType", "lastSenderUid", "lastUpdated", "unreadCounts"
        ])
        && request.resource.data.lastSenderUid == request.auth.uid
        && request.resource.data.unreadCounts[request.auth.uid] == 0
        && request.resource.data.unreadCounts[otherUid] == resource.data.unreadCounts[otherUid] + 1
        && request.resource.data.lastUpdated == request.time
      );
    }

    function validLegacyChatUpgrade() {
      return !resource.data.keys().hasAll([
          "participantTypes", "unreadCounts", "lastMessageType", "lastSenderUid"
        ])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "participantTypes", "unreadCounts", "lastMessageType", "lastSenderUid"
        ])
        && validParticipantTypes(request.resource.data)
        && validUnreadCounts(request.resource.data)
        && request.resource.data.lastMessageType == "text"
        && request.resource.data.lastSenderUid == "";
    }

    function validChatContext(data) {
      return !data.keys().hasAny(["context"])
        || (
          data.context is map
          && exists(/databases/$(database)/documents/services/$(data.context.serviceId))
          && data.context.keys().hasOnly(["serviceId", "title", "image", "price", "sellerUid"])
          && data.context.keys().hasAll(["serviceId", "title", "image", "price", "sellerUid"])
          && data.context.serviceId is string
          && data.context.serviceId.size() > 0
          && data.context.serviceId.size() <= 80
          && data.context.title is string
          && data.context.title.size() > 0
          && data.context.title.size() <= 140
          && data.context.image is string
           && data.context.image.size() <= 3000
          && data.context.price is number
          && data.context.price >= 0
          && data.context.sellerUid in data.participantUids
          && data.context.sellerUid == get(/databases/$(database)/documents/services/$(data.context.serviceId)).data.ownerUid
          && data.context.title == get(/databases/$(database)/documents/services/$(data.context.serviceId)).data.title
          && data.context.price == get(/databases/$(database)/documents/services/$(data.context.serviceId)).data.price
          && (
            data.context.image == ""
            || data.context.image.matches("^https://firebasestorage\\.googleapis\\.com/.*$")
          )
        );
    }

    function validAttachment(data, chatId, messageId) {
      return !data.keys().hasAny(["attachment"])
        || (
          data.attachment is map
          && data.attachment.keys().hasOnly(["name", "url", "path", "size", "contentType"])
          && data.attachment.keys().hasAll(["name", "url", "path", "size", "contentType"])
          && data.attachment.name is string
          && data.attachment.name.size() > 0
          && data.attachment.name.size() <= 160
          && data.attachment.url is string
          && data.attachment.url.size() > 0
          && data.attachment.url.size() <= 3000
          && data.attachment.url.matches("^https://firebasestorage\\.googleapis\\.com/.*$")
          && data.attachment.path is string
          && data.attachment.path.matches("^chat-attachments/" + chatId + "/" + messageId + "/[^/]{1,100}$")
          && data.attachment.size is int
          && data.attachment.size > 0
          && data.attachment.size <= 10 * 1024 * 1024
          && data.attachment.contentType in [
            "image/jpeg", "image/png", "image/webp", "application/pdf", "application/msword",
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/zip", "application/x-zip-compressed"
          ]
        );
    }

    match /users/{userId} {
      function validFreelancerResubmission() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return signedIn()
          && request.auth.uid == userId
          && resource.data.accountType == "freelancer"
          && resource.data.status == "rejected"
          && request.resource.data.accountType == resource.data.accountType
          && request.resource.data.email == resource.data.email
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.status == "pending"
          && changed.hasAll([
            "idNumber", "idName", "idFrontPath", "idBackPath",
            "status", "resubmittedAt", "updatedAt"
          ])
          && changed.hasOnly([
            "name", "phone", "specialty", "idNumber", "idName",
            "idFrontPath", "idBackPath", "status", "resubmittedAt", "updatedAt"
          ])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
          && request.resource.data.phone is string
          && request.resource.data.phone.size() > 0
          && request.resource.data.phone.size() <= 30
          && request.resource.data.specialty is string
          && request.resource.data.specialty.size() > 0
          && request.resource.data.idNumber is string
          && request.resource.data.idNumber.size() > 0
          && request.resource.data.idNumber.size() <= 60
          && request.resource.data.idName is string
          && request.resource.data.idName.size() > 0
          && request.resource.data.idName.size() <= 120
          && request.resource.data.idFrontPath == "identity/" + userId + "/front"
          && request.resource.data.idBackPath == "identity/" + userId + "/back"
          && request.resource.data.resubmittedAt == request.time
          && request.resource.data.updatedAt == request.time;
      }

      function validAdminRankUpdate() {
        return hasAdminPermission("ranks.manage")
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "rank", "manualRank", "updatedAt"
          ]);
      }

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.email == request.auth.token.email
        && !request.resource.data.keys().hasAny(["role"])
        && request.resource.data.keys().hasOnly([
          "name", "email", "phone", "specialty", "idNumber", "idName",
          "idFrontPath", "idBackPath", "accountType", "status",
          "legalAccepted", "legalAcceptedAt", "identityConsent", "identityConsentAt",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 80
        && validEmail(request.resource.data.email)
        && request.resource.data.accountType in ["buyer", "freelancer"]
        && request.resource.data.createdAt == request.time
        && (!request.resource.data.keys().hasAny(["phone"])
          || (request.resource.data.phone is string && request.resource.data.phone.size() <= 30))
        && (!request.resource.data.keys().hasAny(["specialty"])
          || (request.resource.data.specialty is string && request.resource.data.specialty.size() <= 80))
        && (!request.resource.data.keys().hasAny(["idNumber"])
          || (request.resource.data.idNumber is string && request.resource.data.idNumber.size() <= 60))
        && (!request.resource.data.keys().hasAny(["idName"])
          || (request.resource.data.idName is string && request.resource.data.idName.size() <= 120))
        && (!request.resource.data.keys().hasAny(["idFrontPath"])
          || request.resource.data.idFrontPath == "identity/" + userId + "/front")
        && (!request.resource.data.keys().hasAny(["idBackPath"])
          || request.resource.data.idBackPath == "identity/" + userId + "/back")
        && (
          !request.resource.data.keys().hasAny(["legalAccepted", "legalAcceptedAt"])
          || (request.resource.data.legalAccepted == true && request.resource.data.legalAcceptedAt == request.time)
        )
        && (
          !request.resource.data.keys().hasAny(["identityConsent", "identityConsentAt"])
          || (request.resource.data.identityConsent == true && request.resource.data.identityConsentAt == request.time)
        )
        && (
          (request.resource.data.accountType == "buyer" && request.resource.data.status == "active")
          || (request.resource.data.accountType == "freelancer" && request.resource.data.status == "pending")
        );

      allow get: if signedIn() && (request.auth.uid == userId
        || hasAdminPermission("users.view") || hasAdminPermission("verifications.view")
        || isSuperAdmin());
      allow list: if hasAdminPermission("users.view")
        || hasAdminPermission("verifications.view")
        || isSuperAdmin();

      allow update: if validAdminRankUpdate()
        || validFreelancerResubmission()
        || (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["name", "phone", "specialty"])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
          && (
            !request.resource.data.keys().hasAny(["phone"])
            || (
              request.resource.data.phone is string
              && request.resource.data.phone.size() <= 30
            )
          )
          && (
            !request.resource.data.keys().hasAny(["specialty"])
            || (
              request.resource.data.specialty is string
              && request.resource.data.specialty.size() <= 60
            )
          )
        );
      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read: if true;
      allow create: if (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly([
            "name", "accountType", "avatar", "avatarPath", "status", "specialty", "about", "skills", "careerItems"
          ])
          && request.resource.data.accountType in ["buyer", "freelancer"]
          && request.resource.data.name == userAfter(userId).name
          && request.resource.data.accountType == userAfter(userId).accountType
          && request.resource.data.status == userAfter(userId).status
          && (
            !request.resource.data.keys().hasAny(["specialty"])
            || request.resource.data.specialty == userAfter(userId).specialty
          )
          && (
            !request.resource.data.keys().hasAny(["avatar"])
            || (
              request.resource.data.avatar is string
              && request.resource.data.avatar.size() <= 10000
              && (
                request.resource.data.avatar == ""
                || request.resource.data.avatar.matches("^https://firebasestorage\\.googleapis\\.com/.*$")
              )
            )
          )
          && (
            !request.resource.data.keys().hasAny(["avatarPath"])
            || request.resource.data.avatarPath == ""
            || request.resource.data.avatarPath == "profile-images/" + userId + "/avatar"
          )
          && (
            !request.resource.data.keys().hasAny(["about"])
            || (request.resource.data.about is string && request.resource.data.about.size() <= 1200)
          )
          && (
            !request.resource.data.keys().hasAny(["skills"])
            || (request.resource.data.skills is list && request.resource.data.skills.size() <= 20)
          )
          && (
            !request.resource.data.keys().hasAny(["careerItems"])
            || (request.resource.data.careerItems is list && request.resource.data.careerItems.size() <= 8)
          )
        );
      allow update: if (hasAdminPermission("ranks.manage")
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["rank"]))
        || (hasAdminPermission("promotions.manage")
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["badges", "badgeSummary"]))
        || (
          activeUser()
          && request.auth.uid == userId
           && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["name", "avatar", "avatarPath", "specialty", "about", "skills", "careerItems"])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
          && request.resource.data.name == userAfter(userId).name
          && (
            !request.resource.data.keys().hasAny(["specialty"])
            || (
              request.resource.data.specialty is string
              && request.resource.data.specialty.size() <= 60
              && request.resource.data.specialty == userAfter(userId).specialty
            )
          )
           && (
             !request.resource.data.keys().hasAny(["avatar"])
            || (
              request.resource.data.avatar is string
              && request.resource.data.avatar.size() <= 10000
              && (
                request.resource.data.avatar == ""
                || request.resource.data.avatar.matches("^https://firebasestorage\\.googleapis\\.com/.*$")
              )
             )
           )
           && (
             !request.resource.data.keys().hasAny(["avatarPath"])
             || request.resource.data.avatarPath == ""
             || request.resource.data.avatarPath == "profile-images/" + userId + "/avatar"
           )
           && (
             !request.resource.data.keys().hasAny(["about"])
             || (request.resource.data.about is string && request.resource.data.about.size() <= 1200)
           )
            && (
              !request.resource.data.keys().hasAny(["skills"])
              || (request.resource.data.skills is list && request.resource.data.skills.size() <= 20)
            )
            && (
              !request.resource.data.keys().hasAny(["careerItems"])
              || (request.resource.data.careerItems is list && request.resource.data.careerItems.size() <= 8)
            )
          );
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow create: if activeUser()
        && request.resource.data.keys().hasOnly([
          "participantUids", "participantNames", "participantTypes", "unreadCounts",
          "lastMessage", "lastMessageType", "lastSenderUid", "context", "currencyVersion",
          "createdAt", "lastUpdated"
        ])
        && request.resource.data.keys().hasAll([
          "participantUids", "participantNames", "participantTypes", "unreadCounts",
          "lastMessage", "lastMessageType", "lastSenderUid", "currencyVersion", "createdAt", "lastUpdated"
        ])
        && request.resource.data.participantUids.size() == 2
        && request.resource.data.participantUids[0] != request.resource.data.participantUids[1]
        && request.auth.uid in request.resource.data.participantUids
        && activeParticipant(request.resource.data.participantUids[0])
        && activeParticipant(request.resource.data.participantUids[1])
        && validParticipantMap(request.resource.data, "participantNames")
        && validParticipantTypes(request.resource.data)
        && validUnreadCounts(request.resource.data)
        && request.resource.data.participantNames[
          request.resource.data.participantUids[0]
        ] is string
        && request.resource.data.participantNames[
          request.resource.data.participantUids[0]
        ].size() > 0
        && request.resource.data.participantNames[
          request.resource.data.participantUids[0]
        ].size() <= 80
        && request.resource.data.participantNames[request.resource.data.participantUids[0]]
          == get(/databases/$(database)/documents/users/$(request.resource.data.participantUids[0])).data.name
        && request.resource.data.participantNames[
          request.resource.data.participantUids[1]
        ] is string
        && request.resource.data.participantNames[
          request.resource.data.participantUids[1]
        ].size() > 0
        && request.resource.data.participantNames[
          request.resource.data.participantUids[1]
        ].size() <= 80
        && request.resource.data.participantNames[request.resource.data.participantUids[1]]
          == get(/databases/$(database)/documents/users/$(request.resource.data.participantUids[1])).data.name
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 140
        && request.resource.data.lastMessageType in ["text", "attachment", "mixed"]
        && request.resource.data.lastSenderUid == ""
        && request.resource.data.currencyVersion == "SYP_NEW_2026"
        && request.resource.data.createdAt == request.time
        && request.resource.data.lastUpdated == request.time
        && validChatContext(request.resource.data);

      allow read: if hasAdminPermission("conversations.view")
        || (activeUser() && request.auth.uid in resource.data.participantUids);
      allow update: if activeUser()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "participantTypes", "lastMessage", "lastMessageType",
          "lastSenderUid", "lastUpdated", "unreadCounts"
        ])
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 140
        && request.resource.data.lastMessageType in ["text", "attachment", "mixed"]
        && validUnreadCounts(request.resource.data)
        && (validLegacyChatUpgrade() || validChatUpdate());
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.keys().hasOnly([
            "text", "senderUid", "timestamp", "type", "attachment", "readBy"
          ])
          && request.resource.data.keys().hasAll([
            "text", "senderUid", "timestamp", "type", "readBy"
          ])
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000
          && request.resource.data.type in ["text", "attachment", "mixed"]
          && (
            (request.resource.data.type == "text" && request.resource.data.text.size() > 0)
            || (
              request.resource.data.type in ["attachment", "mixed"]
              && request.resource.data.keys().hasAny(["attachment"])
            )
          )
          && request.resource.data.readBy is list
          && request.resource.data.readBy.size() == 1
          && request.resource.data.readBy[0] == request.auth.uid
          && request.resource.data.timestamp == request.time
          && validAttachment(request.resource.data, chatId, messageId);
        allow update: if isChatParticipant(chatId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"])
          && request.resource.data.readBy is list
          && request.resource.data.readBy.hasAll(resource.data.readBy)
          && request.auth.uid in request.resource.data.readBy
          && request.resource.data.readBy.size() <= 2;
        allow delete: if false;
      }
    }

    match /services/{serviceId} {
      allow read: if hasAdminPermission("services.view") || hasAdminPermission("services.moderate")
        || resource.data.status == "published"
        || (activeUser() && resource.data.ownerUid == request.auth.uid);
      allow create: if isAccountType("freelancer")
        && request.resource.data.keys().hasOnly([
          "ownerUid", "ownerName", "title", "category", "description", "price",
          "deliveryDays", "revisions", "keywords", "status", "currencyVersion", "createdAt", "updatedAt"
        ])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() > 0
        && request.resource.data.ownerName.size() <= 100
        && request.resource.data.ownerName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 5
        && request.resource.data.title.size() <= 100
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() <= 80
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 20
        && request.resource.data.description.size() <= 1000
        && request.resource.data.price is number
        && request.resource.data.price >= 1
        && request.resource.data.currencyVersion == "SYP_NEW_2026"
        && request.resource.data.deliveryDays is int
        && request.resource.data.deliveryDays >= 1
        && request.resource.data.deliveryDays <= 90
        && request.resource.data.revisions is int
        && request.resource.data.revisions >= 0
        && request.resource.data.revisions <= 20
        && request.resource.data.keywords is list
        && request.resource.data.keywords.size() <= 12
        && request.resource.data.status == "draft"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if (hasAdminPermission("services.moderate")
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status", "moderationReason", "reviewedAt", "reviewedBy", "updatedAt"
          ]))
        || (
          isAccountType("freelancer")
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "title", "category", "description", "price", "deliveryDays",
            "revisions", "keywords", "status", "imageUrl", "imagePath", "updatedAt"
          ])
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 5
          && request.resource.data.title.size() <= 100
          && request.resource.data.category is string
          && request.resource.data.category.size() > 0
          && request.resource.data.category.size() <= 80
          && request.resource.data.description is string
          && request.resource.data.description.size() >= 20
          && request.resource.data.description.size() <= 1000
          && request.resource.data.price is number
          && request.resource.data.price >= 1
          && request.resource.data.deliveryDays is int
          && request.resource.data.deliveryDays >= 1
          && request.resource.data.deliveryDays <= 90
          && request.resource.data.revisions is int
          && request.resource.data.revisions >= 0
          && request.resource.data.revisions <= 20
          && request.resource.data.keywords is list
          && request.resource.data.keywords.size() <= 12
          && (
            !request.resource.data.keys().hasAny(["imageUrl"])
            || (
              request.resource.data.imageUrl is string
              && request.resource.data.imageUrl.size() <= 3000
              && request.resource.data.imageUrl.matches("^https://firebasestorage\\.googleapis\\.com/.*$")
            )
          )
          && (
            !request.resource.data.keys().hasAny(["imagePath"])
            || request.resource.data.imagePath == "service-images/" + request.auth.uid + "/" + serviceId + "/cover.jpg"
            || request.resource.data.imagePath == "service-images/" + request.auth.uid + "/" + serviceId + "/cover.png"
            || request.resource.data.imagePath == "service-images/" + request.auth.uid + "/" + serviceId + "/cover.webp"
          )
          && (
            request.resource.data.status == "draft"
            || (
              request.resource.data.status == "pending"
              && resource.data.status in ["draft", "rejected", "published", "paused"]
            )
            || (
              request.resource.data.status == "paused"
              && resource.data.status == "published"
            )
          )
          && request.resource.data.updatedAt == request.time
        );
      allow delete: if hasAdminPermission("services.moderate")
        || (
          isAccountType("freelancer")
          && resource.data.ownerUid == request.auth.uid
          && resource.data.status != "pending"
        );
    }

    match /orders/{orderId} {
      allow read: if hasAdminPermission("finance.view")
        || (
          activeUser()
          && (
            resource.data.buyerUid == request.auth.uid
            || resource.data.freelancerUid == request.auth.uid
          )
        );
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.status == "published" || hasAdminPermission("services.view") || hasAdminPermission("services.moderate")
        || (activeUser() && request.auth.uid in [resource.data.reviewerUid, resource.data.targetUid]);
      allow create: if false;
      allow update, delete: if hasAdminPermission("services.moderate");
    }

    match /favorites/{userId}/services/{serviceId} {
      allow read, create, update, delete: if activeUser() && request.auth.uid == userId;
    }

    match /launchSubscribers/{subscriberId} {
      allow create: if false;
      allow read, update, delete: if hasAdminPermission("content.manage");
    }

    match /promoCodeGroups/{groupId} {
      allow read, create, update, delete: if hasAdminPermission("promotions.manage");
    }

    match /promoCodes/{codeId} {
      allow get: if hasAdminPermission("promotions.manage");
      allow list: if hasAdminPermission("promotions.manage");
      allow create: if hasAdminPermission("promotions.manage");
      allow delete: if hasAdminPermission("promotions.manage");
      allow update: if hasAdminPermission("promotions.manage");
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow create, update, delete: if hasAdminPermission("promotions.manage");
    }

    match /userBadges/{badgeDocId} {
      allow read: if hasAdminPermission("promotions.manage") || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if hasAdminPermission("promotions.manage");
      allow update, delete: if hasAdminPermission("promotions.manage");
    }

    match /referrals/{referralId} {
      allow read: if hasAdminPermission("promotions.manage") || (signedIn() && request.auth.uid in [resource.data.inviterUid, resource.data.invitedUid]);
      allow create, update: if hasAdminPermission("promotions.manage");
      allow delete: if hasAdminPermission("promotions.manage");
    }

    match /userBenefits/{benefitId} {
      allow read: if hasAdminPermission("promotions.manage") || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if hasAdminPermission("promotions.manage");
      allow delete: if hasAdminPermission("promotions.manage");
    }

    match /supportTickets/{ticketId} {
      allow create: if false;
      allow read: if hasAdminPermission("support.view") || hasAdminPermission("support.reply")
        || (activeUser() && resource.data.requesterUid == request.auth.uid);
      allow update: if hasAdminPermission("support.reply")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status", "priority", "assignedAdminUid", "updatedAt"
        ]);
      allow delete: if false;

      match /replies/{replyId} {
        function ticket() {
          return get(/databases/$(database)/documents/supportTickets/$(ticketId)).data;
        }

        allow read: if hasAdminPermission("support.view") || hasAdminPermission("support.reply")
          || (activeUser() && ticket().requesterUid == request.auth.uid);
        allow create: if (
            hasAdminPermission("support.reply")
            || (activeUser() && ticket().requesterUid == request.auth.uid)
          )
          && request.resource.data.keys().hasOnly([
            "authorUid", "authorRole", "authorName", "text", "createdAt"
          ])
          && request.resource.data.keys().hasAll([
            "authorUid", "authorRole", "authorName", "text", "createdAt"
          ])
          && request.resource.data.authorUid == request.auth.uid
          && (
            (hasAdminPermission("support.reply") && request.resource.data.authorRole == "admin")
            || (
              activeUser()
              && ticket().requesterUid == request.auth.uid
              && request.resource.data.authorRole == "user"
            )
          )
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 160
          && request.resource.data.authorName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    match /notifications/{userId}/items/{notificationId} {
      allow read: if activeUser() && request.auth.uid == userId;
      allow create: if (
          hasAdminPermission("verifications.manage")
          || hasAdminPermission("services.moderate")
          || hasAdminPermission("support.reply")
        ) && validAdminNotification(request.resource.data);
      allow update: if activeUser()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"])
        && request.resource.data.read is bool;
      allow delete: if activeUser() && request.auth.uid == userId;
    }

    match /articles/{articleId} {
      allow read: if hasAdminPermission("content.view") || hasAdminPermission("content.manage") || resource.data.status == "published";
      allow create, delete: if false;
      allow update: if false;

      match /likes/{userId} {
        allow read: if hasAdminPermission("content.view") || hasAdminPermission("content.manage")
          || get(/databases/$(database)/documents/articles/$(articleId)).data.status == "published";
        allow create: if activeUser()
          && get(/databases/$(database)/documents/articles/$(articleId)).data.status == "published"
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(["userUid", "createdAt"])
          && request.resource.data.userUid == request.auth.uid
          && request.resource.data.createdAt == request.time;
        allow delete: if hasAdminPermission("content.manage") || (activeUser() && userId == request.auth.uid);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if hasAdminPermission("content.view") || hasAdminPermission("content.manage")
          || (
            get(/databases/$(database)/documents/articles/$(articleId)).data.status == "published"
            && resource.data.status == "published"
          );
        allow create: if activeUser()
          && get(/databases/$(database)/documents/articles/$(articleId)).data.status == "published"
          && request.resource.data.keys().hasOnly([
            "authorUid", "authorName", "text", "status", "createdAt"
          ])
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 100
          && request.resource.data.authorName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1500
          && request.resource.data.status == "published"
          && request.resource.data.createdAt == request.time;
        allow delete: if hasAdminPermission("content.manage") || (activeUser() && resource.data.authorUid == request.auth.uid);
        allow update: if hasAdminPermission("content.manage")
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]);
      }

      match /revisions/{revisionId} {
        allow read: if hasAdminPermission("content.view") || hasAdminPermission("content.manage");
        allow write: if false;
      }
    }

    match /articleBodies/{articleId} {
      allow read: if hasAdminPermission("content.view") || hasAdminPermission("content.manage")
        || get(/databases/$(database)/documents/articles/$(articleId)).data.status == "published";
      allow write: if false;
    }

    match /articleViews/{viewId} {
      allow read, write: if false;
    }

    match /articleCategories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /adminOperations/{operationId} {
      allow read, write: if false;
    }

    match /systemEvents/{eventId} {
      allow read, write: if false;
    }

    match /faqItems/{itemId} {
      allow read: if hasAdminPermission("content.view") || hasAdminPermission("content.manage") || resource.data.published == true;
      allow create, update, delete: if hasAdminPermission("content.manage");
    }

    match /freelancerPortfolio/{itemId} {
      allow read: if hasAdminPermission("services.view") || hasAdminPermission("services.moderate")
        || resource.data.published == true
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 100
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 600
        && request.resource.data.mediaType in ["image", "video"]
        && request.resource.data.mediaPath is string
        && request.resource.data.mediaPath.size() <= 3000
        && request.resource.data.published is bool;
      allow update: if hasAdminPermission("services.moderate")
        || (
          signedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 3
          && request.resource.data.title.size() <= 100
          && request.resource.data.category is string
          && request.resource.data.category.size() > 0
          && request.resource.data.category.size() <= 60
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 600
          && request.resource.data.mediaType in ["image", "video"]
          && request.resource.data.mediaPath is string
          && request.resource.data.mediaPath.size() <= 3000
          && request.resource.data.published is bool
        );
      allow delete: if hasAdminPermission("services.moderate")
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
    }

    match /portfolioItems/{itemId} {
      allow read: if hasAdminPermission("services.view") || hasAdminPermission("services.moderate")
        || resource.data.published == true
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 100
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 600
        && request.resource.data.mediaType in ["image", "video"]
        && request.resource.data.mediaPath is string
        && request.resource.data.mediaPath.size() <= 3000
        && request.resource.data.published is bool;
      allow update: if hasAdminPermission("services.moderate")
        || (
          signedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 3
          && request.resource.data.title.size() <= 100
          && request.resource.data.category is string
          && request.resource.data.category.size() > 0
          && request.resource.data.category.size() <= 60
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 600
          && request.resource.data.mediaType in ["image", "video"]
          && request.resource.data.mediaPath is string
          && request.resource.data.mediaPath.size() <= 3000
          && request.resource.data.published is bool
        );
      allow delete: if hasAdminPermission("services.moderate")
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
    }

    match /serviceCategories/{categoryId} {
      allow read: if hasAdminPermission("content.view") || hasAdminPermission("content.manage") || resource.data.active == true;
      allow create, update, delete: if hasAdminPermission("content.manage");
    }

    match /adminAuditLogs/{logId} {
      allow read: if hasAdminPermission("audit.view");
      allow create: if canCreateAuditAction(request.resource.data.action)
        && request.resource.data.keys().hasOnly([
          "action", "actorUid", "actorName", "actorEmail",
          "targetUid", "targetName", "targetEmail", "reason", "createdAt"
        ])
        && request.resource.data.keys().hasAll([
          "action", "actorUid", "actorName", "actorEmail",
          "targetUid", "targetName", "targetEmail", "reason", "createdAt"
        ])
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("name", get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email)
        && request.resource.data.actorEmail == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email
        && request.resource.data.action in [
          "approve_user", "reject_user", "suspend_user",
          "activate_user", "update_settings", "update_ticket",
          "reply_ticket", "create_article", "update_article",
          "delete_article", "manage_faq", "manage_category",
          "approve_service", "reject_service", "delete_service",
          "update_freelancer_rank", "create_promo_codes", "assign_badge", "create_badge"
        ]
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.targetUid is string
        && request.resource.data.targetUid.size() <= 128
        && request.resource.data.targetName is string
        && request.resource.data.targetName.size() <= 160
        && request.resource.data.targetEmail is string
        && request.resource.data.targetEmail.size() <= 160
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /wallets/{userId} {
      allow read: if hasAdminPermission("finance.view") || (activeUser() && request.auth.uid == userId);
      allow create, update, delete: if false;
    }

    match /walletLedger/{entryId} {
      allow read: if hasAdminPermission("finance.view") || (activeUser() && resource.data.userUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /depositRequests/{requestId} {
      allow read: if hasAdminPermission("finance.view") || (activeUser() && resource.data.userUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /withdrawalRequests/{requestId} {
      allow read: if hasAdminPermission("finance.view") || (activeUser() && resource.data.userUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /payoutMethods/{userId}/items/{methodId} {
      allow read: if hasAdminPermission("finance.view") || (activeUser() && request.auth.uid == userId);
      allow create, update, delete: if false;
    }

    match /accountBenefits/{userId} {
      allow read: if hasAdminPermission("promotions.manage") || (activeUser() && request.auth.uid == userId);
      allow create, update: if hasAdminPermission("promotions.manage");
      allow delete: if hasAdminPermission("promotions.manage");
    }

    match /paymentProviderReferences/{referenceId} {
      allow read, write: if false;
    }

    match /mailQueue/{mailId} {
      allow read: if hasAdminPermission("support.reply") || hasAdminPermission("finance.manage");
      allow create, update, delete: if false;
    }

    match /platformSettings/{settingId} {
      allow read: if true;
      allow create: if hasAdminPermission("settings.manage")
        && settingId == "general"
        && validPlatformSettings(request.resource.data);
      allow update: if settingId == "general"
        && validPlatformSettings(request.resource.data)
        && (hasAdminPermission("settings.manage")
          || (hasAdminPermission("promotions.manage")
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "homeFeaturedBadgeIds", "homeFeaturedCriteria", "updatedAt", "updatedBy"
            ])));
      allow delete: if false;
    }

    match /adminRoles/{roleId} {
      allow read: if isSuperAdmin()
        || (isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRoleId == roleId);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
