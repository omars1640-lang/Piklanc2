rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function activeUser() {
      return signedIn()
        && request.auth.token.email_verified == true
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.status == "active";
    }

    function activePortfolioOwner(userId) {
      let user = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      return signedIn()
        && request.auth.uid == userId
        && user.status == "active"
        && user.accountType == "freelancer";
    }

    function isChatParticipant(chatId) {
      return activeUser()
        && request.auth.uid in firestore.get(
          /databases/(default)/documents/chats/$(chatId)
        ).data.participantUids;
    }

    match /identity/{userId}/{fileName} {
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && fileName in ["front", "back"]
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
      allow delete: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /chat-attachments/{chatId}/{messageId}/{fileName} {
      allow create: if isChatParticipant(chatId)
        && request.resource.size > 0
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches(
          "image/(jpeg|png|webp)|application/(pdf|msword|vnd.openxmlformats-officedocument.wordprocessingml.document|zip|x-zip-compressed)"
        );
      allow read: if isChatParticipant(chatId);
      allow delete: if isChatParticipant(chatId);
      allow update: if false;
    }

    match /article-covers/{articleId}/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if isAdmin();
    }

    match /service-images/{userId}/{serviceId}/{fileName} {
      allow read: if true;
      allow create, update: if activeUser()
        && request.auth.uid == userId
        && fileName.matches("cover\\.(jpg|png|webp)")
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if isAdmin() || (activeUser() && request.auth.uid == userId);
    }

    match /profile-images/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if activeUser()
        && request.auth.uid == userId
        && fileName == "avatar"
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if activeUser() && request.auth.uid == userId && fileName == "avatar";
    }

    match /portfolio-images/{userId}/{itemId}/{fileName} {
      allow read: if true;
      allow create, update: if activePortfolioOwner(userId)
        && fileName.matches("cover\\.(jpg|png|webp)")
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
      allow delete: if isAdmin() || activePortfolioOwner(userId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
